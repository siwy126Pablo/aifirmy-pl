---
import Layout from '../layouts/Layout.astro';
import CompanyCard from '../components/CompanyCard.astro';
import CategoryIcon from '../components/icons/CategoryIcon.astro';
import { supabase } from '../lib/supabase';

const { data: companies, error } = await supabase
  .from('tools')
  .select('*, categories(name_pl, slug), premium_listings(id, plan, ends_at), affiliate_links(affiliate_url, disclosure_text, active)')
  .eq('status', 'approved')
  .order('created_at', { ascending: false });

if (error) console.error('Supabase error:', error);

const sorted = [...(companies ?? [])].sort((a, b) => {
  const aP = a.premium_listings?.some((p: any) => p.ends_at && new Date(p.ends_at) > new Date()) ? 1 : 0;
  const bP = b.premium_listings?.some((p: any) => p.ends_at && new Date(p.ends_at) > new Date()) ? 1 : 0;
  return bP - aP;
});

const { data: categoryList } = await supabase
  .from('categories')
  .select('id, slug, name_pl')
  .order('sort_order');

const categoryCounts = new Map<string, number>();
for (const tool of companies ?? []) {
  if (!tool.category_id) continue;
  categoryCounts.set(tool.category_id, (categoryCounts.get(tool.category_id) ?? 0) + 1);
}

const categoryTiles = (categoryList ?? []).map(cat => ({
  ...cat,
  count: categoryCounts.get(cat.id) ?? 0,
}));

const categoryHoverBorder: Record<string, string> = {
  'Automatyzacja procesów': 'hover:border-violet-300',
  'Analityka i BI': 'hover:border-blue-300',
  'Finanse i księgowość': 'hover:border-emerald-300',
  'HR i rekrutacja': 'hover:border-orange-300',
  'Marketing i content': 'hover:border-pink-300',
  'Obsługa klienta': 'hover:border-teal-300',
  'Prawo i compliance': 'hover:border-amber-300',
  'Sprzedaż i CRM': 'hover:border-red-300',
  'Zarządzanie projektami': 'hover:border-gray-300',
};

function pluralizeTools(n: number): string {
  if (n === 1) return 'narzędzie';
  if (n >= 2 && n <= 4) return 'narzędzia';
  return 'narzędzi';
}
---

<Layout
  title="Katalog narzędzi AI"
  description="Największy katalog narzędzi AI dla polskiego rynku. Znajdź aplikacje, SaaS i startupy sztucznej inteligencji — z opisami, kategoriami i informacją o cenach."
>
  <div class="min-h-screen bg-gray-50">

    <main class="mx-auto max-w-5xl px-4 py-12">

      <!-- Hero -->
      <section class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight text-gray-900">
          Katalog narzędzi AI<br />
          <span class="text-indigo-600">dla polskiego rynku</span>
        </h1>
        <p class="mx-auto max-w-xl text-lg text-gray-500">
          Przejrzyste opisy, kategorie i informacje o cenach — wszystko w jednym miejscu.
        </p>
      </section>

      <!-- Kategorie -->
      <section class="mb-12">
        <h2 class="mb-6 text-sm font-semibold uppercase tracking-wide text-gray-400">
          Kategorie
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {categoryTiles.map(cat => (
            <a
              href={`/kategoria/${cat.slug}`}
              class={`flex items-center gap-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:shadow-md ${categoryHoverBorder[cat.name_pl] ?? 'hover:border-gray-300'}`}
            >
              <CategoryIcon category={cat.name_pl} size={40} />
              <div class="min-w-0">
                <p class="truncate font-semibold text-gray-900">{cat.name_pl}</p>
                <p class="text-sm text-gray-500">{cat.count} {pluralizeTools(cat.count)}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Karty firm -->
      <section>
        <h2 class="mb-6 text-sm font-semibold uppercase tracking-wide text-gray-400">
          Najnowsze wpisy
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sorted.map(tool => {
            const isPremium = tool.premium_listings?.some(
              (p: any) => p.ends_at && new Date(p.ends_at) > new Date()
            );
            const activeAffiliateLink = (tool.affiliate_links ?? []).find((link: any) => link.active);
            return (
              <CompanyCard
                name={tool.name}
                description={tool.description_pl ?? tool.tagline_pl ?? ''}
                category={tool.categories?.name_pl ?? ''}
                pricing={tool.pricing_model ?? 'free'}
                url={tool.website_url}
                slug={tool.slug}
                isPremium={isPremium}
                affiliateUrl={activeAffiliateLink?.affiliate_url}
                disclosureText={activeAffiliateLink?.disclosure_text}
                rodoCompliant={tool.rodo_compliant}
                aiActRisk={tool.ai_act_risk}
                logoUrl={tool.logo_url}
              />
            );
          })}
        </div>
      </section>

    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      © {new Date().getFullYear()} aifirmy.pl ·{' '}
      <a href="/polityka-prywatnosci" class="hover:text-gray-600 hover:underline">
        Polityka prywatności
      </a>
    </footer>

  </div>
</Layout>
