---
import Layout from '../layouts/Layout.astro';
import CompanyCard from '../components/CompanyCard.astro';

const companies = [
  {
    slug: 'cursor',
    name: 'Cursor',
    description:
      'Edytor kodu oparty na AI, który rozumie kontekst całego projektu. Pozwala pisać, refaktoryzować i debugować kod przez rozmowę z modelem GPT-4 lub Claude bezpośrednio w edytorze.',
    category: 'Narzędzia deweloperskie',
    pricing: 'freemium' as const,
    url: 'https://cursor.com',
  },
  {
    slug: 'perplexity',
    name: 'Perplexity AI',
    description:
      'Wyszukiwarka konwersacyjna korzystająca z dużych modeli językowych. Odpowiada na pytania w czasie rzeczywistym, cytując źródła — alternatywa dla tradycyjnych wyszukiwarek.',
    category: 'Wyszukiwarki AI',
    pricing: 'freemium' as const,
    url: 'https://perplexity.ai',
  },
  {
    slug: 'eleven-labs',
    name: 'ElevenLabs',
    description:
      'Platforma do syntezy i klonowania głosu z użyciem AI. Generuje realistyczną mowę w wielu językach — popularna w produkcji podcastów, audiobooków i narracji wideo.',
    category: 'Audio i głos',
    pricing: 'freemium' as const,
    url: 'https://elevenlabs.io',
  },
];
---

<Layout
  title="Katalog narzędzi AI"
  description="Największy katalog narzędzi AI dla polskiego rynku. Znajdź aplikacje, SaaS i startupy sztucznej inteligencji — z opisami, kategoriami i informacją o cenach."
>
  <div class="min-h-screen bg-gray-50">

    <!-- Nagłówek -->
    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-6">
        <a href="/" class="text-xl font-bold text-indigo-600">aifirmy.pl</a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-12">

      <!-- Hero -->
      <section class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold tracking-tight text-gray-900">
          Katalog narzędzi AI<br />
          <span class="text-indigo-600">dla polskiego rynku</span>
        </h1>
        <p class="mx-auto max-w-xl text-lg text-gray-500">
          Przejrzyste opisy, kategorie i informacje o cenach — wszystko w jednym miejscu.
        </p>
      </section>

      <!-- Karty firm -->
      <section>
        <h2 class="mb-6 text-sm font-semibold uppercase tracking-wide text-gray-400">
          Najnowsze wpisy
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {companies.map((company) => (
            <CompanyCard {...company} />
          ))}
        </div>
      </section>

    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      © {new Date().getFullYear()} aifirmy.pl
    </footer>

  </div>
</Layout>
