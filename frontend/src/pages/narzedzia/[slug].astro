---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: tools } = await supabase
    .from('tools')
    .select('*, categories(name_pl, slug)')
    .eq('status', 'approved');

  return tools?.map(tool => ({
    params: { slug: tool.slug },
    props: { tool }
  })) ?? [];
}

const { tool } = Astro.props;

const pricingLabel: Record<string, string> = {
  free: 'Bezpłatne',
  freemium: 'Freemium',
  paid: 'Płatne',
  open_source: 'Open Source'
};

const pricingColor: Record<string, string> = {
  free: 'bg-green-100 text-green-700',
  freemium: 'bg-blue-100 text-blue-700',
  paid: 'bg-orange-100 text-orange-700',
  open_source: 'bg-purple-100 text-purple-700',
};

const pricing = tool.pricing_model ?? 'free';
const categoryName = tool.categories?.name_pl ?? '';
const categorySlug = tool.categories?.slug ?? '';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  description: tool.description_pl ?? tool.tagline_pl,
  url: tool.website_url,
  applicationCategory: categoryName,
});
---

<Layout
  title={tool.name}
  description={tool.tagline_pl ?? tool.description_pl ?? ''}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <div class="min-h-screen bg-gray-50">

    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-3xl px-4 py-6">
        <a href="/" class="text-xl font-bold text-indigo-600">aifirmy.pl</a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10">

      <a href="/" class="mb-8 inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600">
        ← Powrót do katalogu
      </a>

      <article class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">

        <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
          <h1 class="text-3xl font-bold text-gray-900">{tool.name}</h1>
          <span class={`rounded-full px-3 py-1 text-sm font-medium ${pricingColor[pricing]}`}>
            {pricingLabel[pricing]}
          </span>
        </div>

        {categoryName && (
          <p class="mb-6 text-sm text-gray-400">
            Kategoria:&nbsp;
            <a href={`/kategoria/${categorySlug}`} class="font-medium text-indigo-600 hover:underline">
              {categoryName}
            </a>
          </p>
        )}

        {tool.tagline_pl && (
          <p class="mb-4 text-lg font-medium text-gray-700">{tool.tagline_pl}</p>
        )}

        <p class="mb-8 text-base leading-relaxed text-gray-600">
          {tool.description_pl}
        </p>

        <div class="mb-8 flex flex-wrap gap-3 text-sm text-gray-500">
          {tool.rodo_compliant && (
            <span class="rounded-md bg-green-50 px-2.5 py-1 text-green-700">✓ RODO</span>
          )}
          {tool.eu_data_hosting && (
            <span class="rounded-md bg-blue-50 px-2.5 py-1 text-blue-700">✓ Hosting UE</span>
          )}
          {tool.has_pl_ui && (
            <span class="rounded-md bg-indigo-50 px-2.5 py-1 text-indigo-700">✓ Interfejs PL</span>
          )}
          {tool.ai_act_risk && (
            <span class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-600">
              AI Act: {tool.ai_act_risk}
            </span>
          )}
        </div>

        <a
          href={tool.website_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-700"
        >
          Odwiedź stronę →
        </a>

      </article>
    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      © {new Date().getFullYear()} aifirmy.pl
    </footer>

  </div>
</Layout>