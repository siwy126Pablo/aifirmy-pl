---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import { companies } from '../../data/companies';

export const getStaticPaths: GetStaticPaths = () =>
  companies.map((company) => ({
    params: { slug: company.slug },
    props: { company },
  }));

const { company } = Astro.props;

const pricingLabel = { free: 'Bezpłatne', freemium: 'Freemium', paid: 'Płatne' } as const;
const pricingColor = {
  free: 'bg-green-100 text-green-700',
  freemium: 'bg-blue-100 text-blue-700',
  paid: 'bg-orange-100 text-orange-700',
} as const;

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: company.name,
  description: company.description,
  url: company.url,
  applicationCategory: company.category,
  keywords: company.tags.join(', '),
  offers: {
    '@type': 'Offer',
    price: company.pricing === 'paid' ? null : '0',
    priceCurrency: 'USD',
    description: pricingLabel[company.pricing],
  },
});
---

<Layout title={company.name} description={company.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <div class="min-h-screen bg-gray-50">

    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-3xl px-4 py-6">
        <a href="/" class="text-xl font-bold text-indigo-600">aifirmy.pl</a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10">

      <!-- Breadcrumb -->
      <a
        href="/"
        class="mb-8 inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600"
      >
        ← Powrót do katalogu
      </a>

      <article class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">

        <!-- Nagłówek karty -->
        <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
          <h1 class="text-3xl font-bold text-gray-900">{company.name}</h1>
          <span class={`rounded-full px-3 py-1 text-sm font-medium ${pricingColor[company.pricing]}`}>
            {pricingLabel[company.pricing]}
          </span>
        </div>

        <!-- Kategoria -->
        <p class="mb-6 text-sm text-gray-400">
          Kategoria:&nbsp;
          <a
            href={`/kategoria/${company.category.toLowerCase().replace(/\s+/g, '-')}`}
            class="font-medium text-indigo-600 hover:underline"
          >
            {company.category}
          </a>
        </p>

        <!-- Opis -->
        <p class="mb-8 text-base leading-relaxed text-gray-700">{company.description}</p>

        <!-- Tagi -->
        <div class="mb-8 flex flex-wrap gap-2">
          {company.tags.map((tag) => (
            <span class="rounded-md bg-gray-100 px-2.5 py-1 text-xs text-gray-500">
              {tag}
            </span>
          ))}
        </div>

        <!-- CTA -->
        <a
          href={company.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-700"
        >
          Odwiedź stronę →
        </a>

      </article>
    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      © {new Date().getFullYear()} aifirmy.pl
    </footer>

  </div>
</Layout>
