---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { categoryColors, categoryColorFallback } from '../../lib/category-colors';

export async function getStaticPaths() {
  const { data: tools } = await supabase
    .from('tools')
    .select('*, categories(name_pl, slug), tool_tags(tags(name_pl, slug)), affiliate_links(affiliate_url, disclosure_text, active)')
    .eq('status', 'approved');

  return tools?.map(tool => ({
    params: { slug: tool.slug },
    props: { tool }
  })) ?? [];
}

const { tool } = Astro.props;

const pricingLabel: Record<string, string> = {
  free: 'Bezpłatne',
  freemium: 'Freemium',
  paid: 'Płatne',
  open_source: 'Open Source'
};

const pricingColor: Record<string, string> = {
  free: 'bg-green-100 text-green-700',
  freemium: 'bg-blue-100 text-blue-700',
  paid: 'bg-orange-100 text-orange-700',
  open_source: 'bg-purple-100 text-purple-700',
};

const pricing = tool.pricing_model ?? 'free';
const categoryName = tool.categories?.name_pl ?? '';
const categorySlug = tool.categories?.slug ?? '';
const placeholderColor = categoryColors[categoryName] ?? categoryColorFallback;
const tags = (tool.tool_tags ?? []).map((tt: any) => tt.tags).filter(Boolean);

const activeAffiliateLink = (tool.affiliate_links ?? []).find((link: any) => link.active);
const ctaUrl = activeAffiliateLink?.affiliate_url ?? tool.website_url;

let similarTools: any[] = [];

if (tool.category_id) {
  const { data } = await supabase
    .from('tools')
    .select('id, slug, name, tagline_pl, description_pl, logo_url, created_at')
    .eq('category_id', tool.category_id)
    .eq('status', 'approved')
    .neq('id', tool.id)
    .order('created_at', { ascending: false })
    .limit(3);
  similarTools = data ?? [];
}

const stillNeeded = 3 - similarTools.length;

if (stillNeeded > 0) {
  const { data: toolTagRows } = await supabase
    .from('tool_tags')
    .select('tag_id')
    .eq('tool_id', tool.id);
  const tagIds = (toolTagRows ?? []).map((r: any) => r.tag_id);

  if (tagIds.length > 0) {
    const excludeIds = new Set([tool.id, ...similarTools.map(t => t.id)]);
    const { data: tagMatchRows } = await supabase
      .from('tool_tags')
      .select('tools!inner(id, slug, name, tagline_pl, description_pl, logo_url, created_at, status)')
      .in('tag_id', tagIds)
      .eq('tools.status', 'approved');

    const extra: any[] = [];
    for (const row of (tagMatchRows ?? []) as any[]) {
      const t = row.tools;
      if (!t || excludeIds.has(t.id)) continue;
      excludeIds.add(t.id);
      extra.push(t);
    }
    extra.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
    similarTools = [...similarTools, ...extra.slice(0, stillNeeded)];
  }
}

function truncate(text: string, max: number) {
  return text.length > max ? `${text.slice(0, max).trimEnd()}…` : text;
}

const aiActBadgeColor: Record<string, string> = {
  minimal: 'bg-green-100 text-green-700',
  limited: 'bg-yellow-100 text-yellow-700',
  high: 'bg-red-100 text-red-700',
  unacceptable: 'bg-red-200 text-red-900',
};

const pricingExplanation: Record<string, string> = {
  free: 'oznacza to, że korzystanie z narzędzia jest całkowicie bezpłatne.',
  freemium: 'oznacza to, że podstawowa wersja jest darmowa, a zaawansowane funkcje wymagają płatnej subskrypcji.',
  paid: 'oznacza to, że korzystanie z narzędzia wymaga wykupienia licencji lub subskrypcji.',
  open_source: 'oznacza to, że kod źródłowy jest publicznie dostępny, a narzędzie można używać i modyfikować bezpłatnie.',
};

const aiActExplanation: Record<string, string> = {
  minimal: 'minimalne',
  limited: 'ograniczone',
  high: 'wysokie',
  unacceptable: 'niedopuszczalne',
};

const targetSizeLabels: Record<string, string> = {
  smb: 'małych i średnich firm',
  mid: 'firm średniej wielkości',
  enterprise: 'dużych organizacji (enterprise)',
};

const targetSizeText = ((tool.target_size ?? []) as string[])
  .map((t: string) => targetSizeLabels[t] ?? t)
  .join(', ');

const faqs = [
  {
    question: `Czy ${tool.name} jest zgodne z RODO?`,
    answer: tool.rodo_compliant
      ? `Tak — ${tool.name} spełnia wymogi RODO, co jest istotne dla firm przetwarzających dane osobowe w UE.`
      : 'Brak potwierdzonej zgodności z RODO — zalecamy weryfikację bezpośrednio u dostawcy przed wdrożeniem.',
  },
  {
    question: `Jaki jest model cenowy ${tool.name}?`,
    answer: `${pricingLabel[pricing]} — ${pricingExplanation[pricing] ?? ''}`,
  },
  ...(tool.ai_act_risk
    ? [{
        question: `Jaki poziom ryzyka według unijnego AI Act ma ${tool.name}?`,
        answer: `${tool.name} klasyfikowane jest jako ryzyko ${aiActExplanation[tool.ai_act_risk] ?? tool.ai_act_risk} zgodnie z unijnym AI Act.${tool.ai_act_notes ? ' ' + tool.ai_act_notes : ''}`,
      }]
    : []),
  {
    question: `Dla jakich firm nadaje się ${tool.name}?`,
    answer: targetSizeText
      ? `Narzędzie dopasowane do: ${targetSizeText}.`
      : 'Brak danych o dedykowanej wielkości firmy — narzędzie może być odpowiednie niezależnie od rozmiaru organizacji.',
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  description: tool.description_pl ?? tool.tagline_pl,
  url: tool.website_url,
  applicationCategory: categoryName,
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
});
---

<Layout
  title={tool.name}
  description={tool.tagline_pl ?? tool.description_pl ?? ''}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
    <script type="application/ld+json" set:html={faqSchema} />
  </Fragment>

  <div class="min-h-screen bg-gray-50">

    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-3xl px-4 py-6">
        <a href="/" class="text-xl font-bold text-indigo-600">aifirmy.pl</a>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-10">

      <a href="/" class="mb-8 inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600">
        ← Powrót do katalogu
      </a>

      <article class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">

        {tool.logo_url ? (
          <img src={tool.logo_url} alt={`Logo ${tool.name}`}
            class="mb-4 h-14 w-14 rounded-xl object-contain border border-gray-100" />
        ) : (
          <span class={`mb-4 flex h-14 w-14 items-center justify-center rounded-xl text-2xl font-semibold ${placeholderColor.bg} ${placeholderColor.text}`}>
            {tool.name?.charAt(0).toUpperCase()}
          </span>
        )}

        <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
          <h1 class="text-3xl font-bold text-gray-900">{tool.name}</h1>
          <span class={`rounded-full px-3 py-1 text-sm font-medium ${pricingColor[pricing]}`}>
            {pricingLabel[pricing]}
          </span>
        </div>

        {(tool.rodo_compliant || tool.ai_act_risk) && (
          <div class="mb-4 flex flex-wrap gap-1.5">
            {tool.rodo_compliant && (
              <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">
                ✓ RODO
              </span>
            )}
            {tool.ai_act_risk && (
              <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${aiActBadgeColor[tool.ai_act_risk]}`}>
                AI Act: {tool.ai_act_risk}
              </span>
            )}
          </div>
        )}

        {categoryName && (
          <p class="mb-6 text-sm text-gray-400">
            Kategoria:&nbsp;
            <a href={`/kategoria/${categorySlug}`} class="font-medium text-indigo-600 hover:underline">
              {categoryName}
            </a>
          </p>
        )}

        {tool.tagline_pl && (
          <p class="mb-4 text-lg font-medium text-gray-700">{tool.tagline_pl}</p>
        )}

        <p class="mb-8 text-base leading-relaxed text-gray-600">
          {tool.description_pl}
        </p>

        <div class="mb-8 flex flex-wrap gap-3 text-sm text-gray-500">
          {tool.rodo_compliant && (
            <span class="rounded-md bg-green-50 px-2.5 py-1 text-green-700">✓ RODO</span>
          )}
          {tool.eu_data_hosting && (
            <span class="rounded-md bg-blue-50 px-2.5 py-1 text-blue-700">✓ Hosting UE</span>
          )}
          {tool.has_pl_ui && (
            <span class="rounded-md bg-indigo-50 px-2.5 py-1 text-indigo-700">✓ Interfejs PL</span>
          )}
          {tool.ai_act_risk && (
            <span class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-600">
              AI Act: {tool.ai_act_risk}
            </span>
          )}
        </div>

        {tags.length > 0 && (
          <div class="mb-8 flex flex-wrap gap-2">
            {tags.map((tag: any) => (
              <span class="rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700">
                {tag.name_pl}
              </span>
            ))}
          </div>
        )}

        <div class="mb-8">
          <h2 class="mb-3 text-xl font-semibold text-gray-900">Najczęściej zadawane pytania</h2>
          <div class="divide-y divide-gray-200 rounded-lg border border-gray-200">
            {faqs.map(faq => (
              <details class="group px-4 py-3 [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-medium text-gray-800 hover:text-indigo-600 focus:text-indigo-600 focus:outline-none">
                  {faq.question}
                  <span class="shrink-0 text-gray-400 transition-transform group-open:rotate-45">+</span>
                </summary>
                <p class="mt-2 text-sm leading-relaxed text-gray-600">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>

        <a
          href={ctaUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-700"
        >
          Odwiedź stronę →
        </a>

        {activeAffiliateLink && (
          <p class="mt-2 text-xs text-gray-500">{activeAffiliateLink.disclosure_text}</p>
        )}

        {similarTools.length > 0 && (
          <div class="mt-10">
            <h2 class="mb-3 text-xl font-semibold text-gray-900">Podobne narzędzia</h2>
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {similarTools.map((t: any) => (
                <a
                  href={`/narzedzia/${t.slug}`}
                  class="flex items-center gap-3 rounded-lg border border-gray-200 bg-white p-3 shadow-sm transition-shadow hover:shadow-md"
                >
                  {t.logo_url ? (
                    <img src={t.logo_url} alt={`Logo ${t.name}`}
                      class="h-9 w-9 shrink-0 rounded-lg border border-gray-100 object-contain" />
                  ) : (
                    <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-sm font-semibold text-indigo-600">
                      {t.name?.charAt(0).toUpperCase()}
                    </span>
                  )}
                  <div class="min-w-0">
                    <p class="truncate text-sm font-medium text-gray-900">{t.name}</p>
                    <p class="truncate text-xs text-gray-500">
                      {t.tagline_pl || truncate(t.description_pl ?? '', 80)}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </article>
    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      © {new Date().getFullYear()} aifirmy.pl ·{' '}
      <a href="/polityka-prywatnosci" class="hover:text-gray-600 hover:underline">
        Polityka prywatności
      </a>
    </footer>

  </div>
</Layout>