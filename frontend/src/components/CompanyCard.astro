---
interface Props {
  name: string;
  description: string;
  category: string;
  pricing: 'free' | 'freemium' | 'paid';
  url: string;
  slug: string;
  isPremium?: boolean;
  affiliateUrl?: string | null;
  disclosureText?: string | null;
  rodoCompliant?: boolean;
  aiActRisk?: 'minimal' | 'limited' | 'high' | 'unacceptable' | null;
}

const { name, description, category, pricing, url, slug, isPremium = false, affiliateUrl, disclosureText, rodoCompliant = false, aiActRisk = null } = Astro.props;

const ctaUrl = affiliateUrl ?? url;

const pricingLabel: Record<Props['pricing'], string> = {
  free: 'Bezpłatne',
  freemium: 'Freemium',
  paid: 'Płatne',
};

const pricingColor: Record<Props['pricing'], string> = {
  free: 'bg-green-100 text-green-700',
  freemium: 'bg-blue-100 text-blue-700',
  paid: 'bg-orange-100 text-orange-700',
};

const aiActColor: Record<string, string> = {
  minimal: 'bg-green-100 text-green-700',
  limited: 'bg-yellow-100 text-yellow-700',
  high: 'bg-red-100 text-red-700',
  unacceptable: 'bg-red-200 text-red-900',
};
---

<article class={`relative flex flex-col gap-3 rounded-xl border p-5 shadow-sm transition-shadow hover:shadow-md ${isPremium ? 'border-indigo-300 bg-indigo-50' : 'border-gray-200 bg-white'}`}>
  {isPremium && (
    <span class="absolute right-0 top-0 rounded-bl-lg rounded-tr-xl bg-indigo-600 px-3 py-1 text-xs font-semibold text-white">
      Polecane
    </span>
  )}
  <div class="flex items-start justify-between gap-2">
    <h2 class="text-lg font-semibold text-gray-900">{name}</h2>
    <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${pricingColor[pricing]}`}>
      {pricingLabel[pricing]}
    </span>
  </div>

  {(rodoCompliant || aiActRisk) && (
    <div class="flex flex-wrap gap-1.5">
      {rodoCompliant && (
        <span class="rounded-full bg-green-50 px-2 py-0.5 text-[11px] font-medium text-green-700">
          ✓ RODO
        </span>
      )}
      {aiActRisk && (
        <span class={`rounded-full px-2 py-0.5 text-[11px] font-medium ${aiActColor[aiActRisk]}`}>
          AI Act: {aiActRisk}
        </span>
      )}
    </div>
  )}

  <p class="line-clamp-6 text-sm text-gray-600">{description}</p>

  <div class="mt-auto flex items-center justify-between pt-1">
    <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500">{category}</span>
    <div class="flex gap-3 text-sm">
      <a
        href={`/narzedzia/${slug}`}
        class="font-medium text-indigo-600 hover:text-indigo-800 hover:underline"
      >
        Szczegóły
      </a>
      <a
        href={ctaUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-gray-600 hover:underline"
      >
        Strona →
      </a>
      {affiliateUrl && (
        <span
          class="cursor-help text-gray-300 hover:text-gray-500"
          title={disclosureText ?? 'Link afiliacyjny — możemy otrzymać prowizję.'}
          aria-label={disclosureText ?? 'Link afiliacyjny — możemy otrzymać prowizję.'}
        >
          ⓘ
        </span>
      )}
    </div>
  </div>
</article>
